{
  "name": "speech-scribe",
  "version": "1.0.0",
  "description": "Parse GCP Speech-to-Text v2 JSON transcripts and reassemble diarized words into per-speaker turns.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "speech-scribe": "dist/cli.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
